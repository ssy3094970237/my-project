<!--pages/first/visit/visit.wxml-->
<view class="form">
  <view class="text">请填写预约信息</view>
  <view class="name">
    <view class="form_text">姓名：</view>
    <input type="text" placeholder="请填写姓名" bindinput="inputName"/>
  </view>
  <view class="phone">
    <view class="form_text">手机号：</view>
    <input type="text" placeholder="请填写手机号" bindinput="inputPhone"/>
  </view>
  <view class="shop">
    <view class="form_text">门店：</view>
    <picker mode='selector' range='{{shop}}' bindchange='bindShopChange' >
      <view>点我{{shopItem}}</view>
    </picker>
  </view>
  <view class="date">
    <view class="form_text">预约日期：</view>
    <picker mode="date" bindchange="bindDateChange">
      <view class="picker">
        {{ date }}
      </view>
    </picker>
  </view>
  <view class="time">
      <view class="form_text">预约时间：</view>
      <picker mode="time" bindchange="bindTimeChange">
        <view class="picker">
          {{ time }}
        </view>
      </picker>
  </view>
</view>
<view class="btn">
  <button bindtap="submitForm">预约</button>
</view>

