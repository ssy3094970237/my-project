/* pages/goods/expend/expend.wxss */
page{
  background-color: rgb(245, 245, 245);
}
/* 商品图片 */
.img{
  height: 550rpx;
  border-bottom: 1rpx solid gray;
}
.img image{
  height: 550rpx;
}
/* 商品名称、价格 */
.message{
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  font-size: large;
  height: 150rpx;
  margin-top: 20rpx;
}
.name{
  width: 550rpx;
  font-weight: 600;
  color: #93a07d;
  font-size: 50rpx;
}
.price{
  width: 180rpx;
  height: 80rpx;
  background-color: #9bb174d3;
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 25rpx 10rpx;
}
/* 商品保障 */
.bao{
  display: flex;
  flex-direction: row;
}
.bao .text{
  letter-spacing: 28rpx;
}
/* 商品详情 */
.desc{
  margin-top: 10rpx;
  display: flex;
  flex-direction: row;
}
.text{
  width: 200rpx;
  font-size: 40rpx;
  font-weight: 600;
  font-style: italic;
}
.content{
  width: 500rpx;
  font-size: 35rpx;
}
/* 加入购物车按钮 */
.btn {
  position: fixed;
  bottom: 0;
  width: 100%;
  height: 50px;
}
button {
  width: 100%;
  height: 100%;
  background-color: #93a07d;
  color: #fff;
  font-size: 18px;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}