/* pages/mine/mine.wxss */
page{
  background-color: rgb(245, 245, 245);
}
/*头像、id栏代码开始 */
.message_card{
  background-color: #93a07d;
  display: flex;
  align-items: center;
  height: 200rpx;
  box-shadow: 0 0 15rpx gainsboro;
  margin-top: 10rpx;
}
.message_card_img{
  width: 250rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.message_card_img image{
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  margin-top: 20rpx;
}
.message_card_text{
  width: 300rpx;
  height: 180rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
/*头像、id栏代码结束 */

/* 余额、积分、优惠券代码开始 */
.yue{
  background-color: #fff;
  height: 200rpx;
  width: 700rpx;
  margin: 30rpx 25rpx;
  border-radius: 10rpx;
  display: flex;
  flex-direction: row;
  box-shadow: 0 0 15rpx gainsboro;
}
.yue_yue,.yue_jifen,.yue_youhui{
  width: 220rpx;
  height: 200rpx;
  margin: 0 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
}
.yue_yue_num{
  color: tomato;
}
/* 余额、积分、优惠券代码结束 */

/* 功能列表代码开始 */
.fun{
  background-color: #fff;
  width: 700rpx;
  height: 220rpx;
  margin: 10rpx 25rpx;
  border-radius: 10rpx;
  display: flex;
  flex-direction: column;
  box-shadow: 0 0 15rpx gainsboro;
}
.fun_text{
  height: 60rpx;
  font-size: 40rpx;
  font-weight: 550;
  margin-left:20rpx;
  margin-top: 10rpx;
}
.fun1{
  height: 170rpx;
  display: flex;
  flex-direction: row;
}
.fun_mini{
  margin: 0 10rpx;
  width: 155rpx;
  height: 150rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
}
.fun image{
  width: 70rpx;
  height: 70rpx;
}
.fun_mini text{
  font-size: 30rpx;
  font-weight: 550;
}
/* 功能列表代码结束 */

/* 更多功能代码开始 */
.more{
  background-color: #fff;
  width: 700rpx;
  height: 450rpx;
  margin: 30rpx 25rpx;
  border-radius: 10rpx;
  display: flex;
  flex-direction: column;
  box-shadow: 0 0 15rpx gainsboro;
}
.more_text{
  height: 60rpx;
  font-size: 40rpx;
  font-weight: 550;
  margin-left:20rpx;
  margin-top: 10rpx; 
}
.more_list{
  height: 80rpx;
  margin-top: 10rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  padding-left: 20rpx;
}
.more_list image{
  width: 50rpx;
  height: 50rpx;
}
.more_list text{
  margin-left: 20rpx;
  font-size: 35rpx;
}
.more_list .more_exit{
  width: 50rpx;
  height: 50rpx;
  margin-left: 380rpx;
}
/* 更多功能代码结束*/
button{
  background-color: #93a07d;
  border-radius: 50rpx;
}
.daodi{
  height: 80rpx;
  display: flex;
  justify-content: center;
}