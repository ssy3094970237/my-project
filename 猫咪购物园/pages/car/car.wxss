page {
  background-color: #f8f7f2;
  padding: 30rpx 30rpx 140rpx;
  margin: 0;
}

/* 商品卡片 */
.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
}
.card_top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 32rpx;
  margin-bottom: 24rpx;
}

/* 商品主体行 */
.main {
  display: flex;
  flex-direction: row;
  align-items: center;
  width: 100%;
}
.card_img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  overflow: hidden;
  flex-shrink: 0;
}
.card_img image {
  width: 100%;
  height: 100%;
}
.middle {
  flex: 1;
  margin: 0 24rpx;
}
.name {
  font-size: 34rpx;
  color: #222;
}
.desc {
  font-size: 26rpx;
  color: #888;
  margin-top: 10rpx;
}
.right {
  text-align: right;
  flex-shrink: 0;
}
.num {
  font-size: 30rpx;
  color: #666;
}
.price {
  font-size: 36rpx;
  color: #e64340;
  font-weight: bold;
  margin-top: 10rpx;
}

.dao {
  text-align: center;
  font-size: 28rpx;
  color: #aaa;
  margin: 40rpx 0;
}

/* 底部结算栏 高度适配按钮 */
.cart-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 130rpx;
  background: #fff;
  display: flex;
  align-items: center;
  flex-direction: row;
  padding: 0 30rpx;
  box-sizing: border-box;
  border-top: 1rpx solid #eee;
}
.check-all {
  display: flex;
  align-items: center;
  font-size: 30rpx;
  flex-shrink: 0;
}
.total-box {
  flex: 1;
  padding: 0 20rpx;
  white-space: nowrap;
}
.total-price {
  font-size: 40rpx;
  color: #e64340;
  font-weight: bold;
}

/* 彻底修复去结算按钮文字偏移问题 */
.pay-btn {
  width: 260rpx;
  height: 96rpx;
  line-height: 96rpx;
  background-color: #93a07d;
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 500;
  border-radius: 96rpx;
  margin: 0;
  flex-shrink: 0;
  border: none;
  padding: 0;
}
/* 清除小程序按钮默认内边距和边框 */
.pay-btn::after {
  border: none;
  margin: 0;
  padding: 0;
}

/* 空购物车样式 */
.content {
  margin-top: 220rpx;
  text-align: center;
}
.hide image {
  width: 240rpx;
  opacity: 0.45;
}
.text {
  font-size: 32rpx;
  color: #999;
  margin-top: 30rpx;
}
.hide button {
  width: 280rpx;
  margin-top: 60rpx;
  background: #93a07d;
  color: #fff;
  font-size: 30rpx;
  border-radius: 12rpx;
}