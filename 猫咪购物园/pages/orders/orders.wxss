/*pages/orders/orders.wxss*/
page{
  background:#f5f5f5;
  padding:20rpx;
}
.tab-wrap{
  display:flex;
  background:#fff;
  border-radius:12rpx;
  margin-bottom:30rpx;
}
.tab-item{
  flex:1;
  text-align:center;
  font-size:32rpx;
  color:#999;
  padding:24rpx 0;
  position:relative;
}
.tab-item.active{
  color:#e64340;
}
.tab-item.active::after{
  content:"";
  width:80rpx;
  height:4rpx;
  background:#e64340;
  position:absolute;
  bottom:0;
  left:50%;
  transform:translateX(-50%);
}
.order-item{
  background:#fff;
  border-radius:16rpx;
  padding:30rpx;
  margin-bottom:20rpx;
  box-shadow:0 0 8rpx #ddd;
}
.shop-name{
  font-size:30rpx;
  color:#333;
}
.order-status{
  float:right;
  font-size:34rpx;
  color:#e64340;
}
.order-content{
  display:flex;
  margin-top:20rpx;
  align-items:center;
}
.goods-img{
  width:140rpx;
  height:140rpx;
  border-radius:8rpx;
}
.goods-info{
  flex:1;
  margin-left:20rpx;
}
.goods-name{
  display:block;
  font-size:34rpx;
}
.goods-spec{
  display:block;
  font-size:26rpx;
  color:#999;
  background:#eee;
  width:140rpx;
  text-align:center;
  border-radius:6rpx;
  margin-top:10rpx;
}
.num-price{
  text-align:right;
}
.price{
  display:block;
  font-size:36rpx;
  color:#333;
  margin-top:10rpx;
}
.empty-box{
  margin-top:200rpx;
  text-align:center;
}
.empty-img{
  width:160rpx;
  height:160rpx;
  opacity:0.4;
}
.empty-text{
  display:block;
  margin-top:20rpx;
  font-size:32rpx;
  color:#999;
}